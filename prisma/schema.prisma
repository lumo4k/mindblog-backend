// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id                   Int      @id @default(autoincrement())
  fullName             String   @map("full_name") @db.VarChar(120)
  email                String   @unique @db.VarChar(191)
  passwordHash         String   @map("password_hash") @db.VarChar(255)
  bio                  String?  @db.Text
  profileImage         Bytes?   @map("profile_image") @db.LongBlob
  profileImageMimeType String?  @map("profile_image_mime_type") @db.VarChar(100)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  articles     Article[]
  articleLikes ArticleLike[]

  @@map("users")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(80)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  articles     Article[]
  articleLikes ArticleLike[]

  @@map("categories")
}

model Article {
  id                 Int    @id @default(autoincrement())
  title              String @db.VarChar(180)
  summary            String @db.VarChar(120)
  content            String @db.LongText
  coverImage         Bytes  @map("cover_image") @db.LongBlob
  coverImageMimeType String @map("cover_image_mime_type") @db.VarChar(100)
  viewCount          Int    @default(0) @map("view_count")

  authorId Int  @map("author_id")
  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  tags  ArticleTag[]
  likes ArticleLike[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([categoryId])
  @@index([createdAt])
  @@map("articles")
}

model Tag {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(30)
  normalizedName String   @unique @map("normalized_name") @db.VarChar(30)
  createdAt      DateTime @default(now()) @map("created_at")

  articles ArticleTag[]

  @@map("tags")
}

model ArticleTag {
  articleId Int @map("article_id")
  tagId     Int @map("tag_id")
  position  Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@unique([articleId, position])
  @@index([tagId])
  @@map("article_tags")
}

model ArticleLike {
  userId    Int      @map("user_id")
  articleId Int      @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  article    Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?

  @@id([userId, articleId])
  @@index([articleId])
  @@map("article_likes")
}
